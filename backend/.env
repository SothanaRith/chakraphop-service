# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ENVIRONMENT CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# NEVER commit this file to version control
# Use .env.example as template for team members
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

NODE_ENV=development

# Server Configuration
PORT=8080
API_VERSION=v1

# Database
DATABASE_URL="mysql://root@localhost:3306/sport_ecommerce"
DB_CONNECTION_LIMIT=10

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-256-bits
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key
JWT_REFRESH_EXPIRES_IN=30d

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Payment Gateways (example configs)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Email (future feature)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=...
EMAIL_FROM=Sport E-Commerce <noreply@example.com>

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Stock Management
LOW_STOCK_ALERT_THRESHOLD=10
STOCK_RESERVATION_TIMEOUT_MINUTES=15

# Redis (for caching and session management - future)
REDIS_URL=redis://localhost:6379

# Monitoring (future integration)
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=
